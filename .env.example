# Copy to .env — use the SAME Supabase project as So1o when accounts are unified.

# Public site URL for SEO (canonical, OG, sitemap) — no trailing slash
# VITE_SITE_URL=https://anthem.app

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key
VITE_SUPABASE_PROJECT_ID=your_project_id

# So1o My Desk (billing + back-office)
# Public URL of So1o (VPS / docker compose)
VITE_SO1O_APP_URL=http://localhost:3000
# VITE_LEGAL_WEBSITE=http://localhost:8081

# Optional: live Stripe tier reads (default sandbox)
# VITE_STRIPE_MODE=live

# So1o webhook → mirror Pro tier (must match So1o ECOSYSTEM_SYNC_SECRET)
# ECOSYSTEM_SYNC_SECRET=

# Supabase CLI only — do NOT put in .env (not VITE_*). Use in terminal:
# export SUPABASE_ACCESS_TOKEN=sbp_...   # https://supabase.com/dashboard/account/tokens
# npm run db:push
